  },
  "dependencies": {
    "gsap": "^3.15.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "autoprefixer": "^10.4.19",
    "jsdom": "^26.1.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.4",
    "vite": "^5.4.1",
    "vitest": "^2.1.9"
